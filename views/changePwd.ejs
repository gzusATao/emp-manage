<!DOCTYPE html>
<html lang="zh-CN">
<head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>修改密码</title><link rel="stylesheet" href="/css/style.css?v=2"></head>
<body class="page">
<div class="container" style="max-width:520px;margin:36px auto;">
<div class="topbar"><div class="topbar-title">修改密码</div><div class="topbar-actions"><a href="/" class="btn btn-outline">返回</a></div></div>
<% if (success) { %><div style="background:rgba(45,212,191,.12);border-left:3px solid var(--teal);color:#99F6E4;padding:10px 14px;border-radius:0 6px 6px 0;font-size:.85rem;margin-bottom:20px;"><%= success %></div><% } %>
<% if (error) { %><div class="login-error"><%= error %></div><% } %>
<form action="/changePwd" method="post">
<div class="form-group"><label class="form-label">原密码</label><input type="password" name="oldPwd" class="form-input" required autofocus></div>
<div class="form-group"><label class="form-label">新密码</label><input type="password" name="newPwd" class="form-input" placeholder="至少6位" required></div>
<div class="form-group"><label class="form-label">确认新密码</label><input type="password" name="confirmPwd" class="form-input" placeholder="再次输入新密码" required></div>
<div class="form-actions"><button type="submit" class="btn btn-primary">保存修改</button></div></form></div></body></html>
