<!DOCTYPE html>
<html lang="zh-CN">
<head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>用户管理</title><link rel="stylesheet" href="/css/style.css?v=2"></head>
<body class="page">
<div class="container">
<div class="topbar"><div class="topbar-title">用户管理</div><div class="topbar-actions"><a href="/" class="btn btn-outline">返回仪表盘</a></div></div>
<div class="add-bar">
<form action="/addUser" method="post" style="display:flex;gap:10px;align-items:center;width:100%;flex-wrap:wrap;">
<input type="text" name="username" class="form-input" placeholder="用户名" required style="width:140px;">
<input type="password" name="password" class="form-input" placeholder="密码" required style="width:140px;">
<select name="role" class="form-select" style="width:110px;"><option value="viewer">访客</option><option value="admin">管理员</option></select>
<button type="submit" class="btn btn-success">添加用户</button></form></div>
<div class="table-shell"><table><thead><tr><th>ID</th><th>用户名</th><th>角色</th><th>创建时间</th><th>操作</th></tr></thead><tbody>
<% users.forEach(function(u) { %><tr>
<td><%= u.user_id %></td><td><strong><%= u.username %></strong></td>
<td><% if (u.role === 'admin') { %><span class="badge-dept" style="background:rgba(251,191,36,.15);color:#FDE68A;">管理员</span><% } else { %><span class="badge-dept">访客</span><% } %></td>
<td style="font-size:.8rem;"><%= u.created_at.toLocaleString('zh-CN') %></td>
<td><% if (u.user_id !== user.user_id) { %><a href="/delUser?id=<%= u.user_id %>" class="btn btn-danger-sm" onclick="return confirm('确认删除？')">删除</a><% } else { %><span style="color:var(--mute);font-size:.8rem;">当前用户</span><% } %></td></tr>
<% }) %></tbody></table></div></div></body></html>
