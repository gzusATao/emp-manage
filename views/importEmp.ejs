<!DOCTYPE html>
<html lang="zh-CN">
<head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>导入员工</title><link rel="stylesheet" href="/css/style.css?v=2"></head>
<body class="page">
<div class="container" style="max-width:640px;margin:36px auto;">
<div class="topbar"><div class="topbar-title">批量导入员工</div><div class="topbar-actions"><a href="/emp" class="btn btn-outline">返回列表</a></div></div>
<% if (result) { %><div style="margin-bottom:20px;padding:12px 16px;border-radius:7px;font-size:.9rem;<%= result.ok ? 'background:rgba(45,212,191,.12);border-left:3px solid var(--teal);color:#99F6E4;' : 'background:rgba(248,113,113,.12);border-left:3px solid var(--alert);color:#FECACA;' %>"><%= result.msg %></div><% } %>
<form action="/importEmp" method="post" enctype="multipart/form-data">
<div class="form-group"><label class="form-label">选择 Excel 文件（.xlsx）</label><input type="file" name="xlsxFile" class="form-input" accept=".xlsx" required></div>
<div class="form-actions"><button type="submit" class="btn btn-primary">开始导入</button></div></form>
<div style="margin-top:28px;padding:18px;background:rgba(255,255,255,.03);border-radius:8px;border:1px solid rgba(255,255,255,.06);">
<div style="font-weight:600;margin-bottom:10px;color:#E2E8F0;">Excel 模板格式</div>
<div style="font-size:.8rem;color:var(--graphite);line-height:2;">第一行为表头，列顺序不限：姓名 部门 出生日期 入职日期 月薪 手机 邮箱 性别 职位</div></div></div></body></html>
