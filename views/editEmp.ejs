<!DOCTYPE html>
<html lang="zh-CN">
<head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>编辑员工</title><link rel="stylesheet" href="/css/style.css?v=2"></head>
<body class="page">
<div class="container" style="max-width:520px;margin:36px auto;">
<div class="topbar"><div class="topbar-title">编辑 <%= empInfo.emp_name %></div></div>
<form action="/editEmp" method="post">
<input type="hidden" name="emp_id" value="<%= empInfo.emp_id %>">
<div class="form-group"><label class="form-label">姓名</label><input type="text" name="emp_name" class="form-input" value="<%= empInfo.emp_name %>" required></div>
<div class="form-group"><label class="form-label">部门</label><select name="emp_dept_id" class="form-select" required><% deptList.forEach(function(item) { %><option value="<%= item.dept_id %>" <%= item.dept_id === empInfo.emp_dept_id ? 'selected' : '' %>><%= item.dept_name %></option><% }) %></select></div>
<div class="form-group"><label class="form-label">出生日期</label><input type="date" name="emp_birth" class="form-input" value="<%= empInfo.emp_birth ? new Date(empInfo.emp_birth).toISOString().slice(0,10) : '' %>"></div>
<div class="form-group"><label class="form-label">入职时间</label><input type="date" name="emp_entry" class="form-input" value="<%= empInfo.emp_entry ? new Date(empInfo.emp_entry).toISOString().slice(0,10) : '' %>"></div>
<div class="form-group"><label class="form-label">月薪（元）</label><input type="number" name="emp_salary" class="form-input" step="0.01" min="0" value="<%= empInfo.emp_salary || '' %>" placeholder="例如：8000"></div>
<div class="form-group"><label class="form-label">手机号</label><input type="text" name="emp_phone" class="form-input" value="<%= empInfo.emp_phone || '' %>"></div>
<div class="form-group"><label class="form-label">邮箱</label><input type="email" name="emp_email" class="form-input" value="<%= empInfo.emp_email || '' %>"></div>
<div class="form-group"><label class="form-label">性别</label><select name="emp_gender" class="form-select"><option value="">请选择</option><option value="男" <%= empInfo.emp_gender === '男' ? 'selected' : '' %>>男</option><option value="女" <%= empInfo.emp_gender === '女' ? 'selected' : '' %>>女</option></select></div>
<div class="form-group"><label class="form-label">职位</label><input type="text" name="emp_position" class="form-input" value="<%= empInfo.emp_position || '' %>" placeholder="例如：前端工程师"></div>
<div class="form-actions"><button type="submit" class="btn btn-accent">保存修改</button><a href="/emp" class="btn btn-outline">返回列表</a></div></form></div></body></html>
